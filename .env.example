# =============================================================================
# .env.example — The Mintlify Sentinel
#
# Copy this file to .env and fill in your actual values.
# .env is listed in .gitignore and will NEVER be committed to the repo.
#
# Usage:
#   Windows PowerShell : $env:SLACK_WEBHOOK_URL="https://hooks.slack.com/..."
#   Linux / macOS      : export SLACK_WEBHOOK_URL="https://hooks.slack.com/..."
#   Or just pass flags : python main.py --slack-webhook URL --discord-webhook URL
# =============================================================================


# =============================================================================
# SLACK
# =============================================================================
# How to get your Slack webhook URL:
#   1. Go to https://api.slack.com/apps
#   2. Create New App → From Scratch → give it a name → pick your workspace
#   3. Features → Incoming Webhooks → toggle ON
#   4. Click "Add New Webhook to Workspace" → select the channel → Allow
#   5. Copy the webhook URL that appears and paste it below
#
# =============================================================================

SLACK_WEBHOOK_URL=PASTE_YOUR_SLACK_WEBHOOK_URL_HERE


# =============================================================================
# DISCORD
# =============================================================================
# How to get your Discord webhook URL:
#   1. Open Discord and go to the server where you want alerts
#   2. Right-click the channel → Edit Channel
#   3. Integrations → Webhooks → New Webhook
#   4. Give it a name (e.g. "Mintlify Sentinel") → Copy Webhook URL
#   5. Paste it below
#
# URL format: https://discord.com/api/webhooks/XXXXXXXXXXXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#
# ⬇⬇⬇ REPLACE THIS PLACEHOLDER WITH YOUR ACTUAL DISCORD WEBHOOK URL ⬇⬇⬇
# =============================================================================

DISCORD_WEBHOOK_URL=PASTE_YOUR_DISCORD_WEBHOOK_URL_HERE

# ⬆⬆⬆ REPLACE THIS PLACEHOLDER WITH YOUR ACTUAL DISCORD WEBHOOK URL ⬆⬆⬆
